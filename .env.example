# === Backend (port 4096) ===
PORT=4096
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=INFO

# Optional: Basic auth for backend API
# OPENCODE_SERVER_PASSWORD=your-password
# OPENCODE_SERVER_USERNAME=opencode

# === LLM Provider API Keys ===
# At least one provider key is required for agent functionality.
# Uncomment and set the providers you want to use.

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google
# GOOGLE_GENERATIVE_AI_API_KEY=...

# AWS Bedrock
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# Groq
# GROQ_API_KEY=gsk_...

# xAI
# XAI_API_KEY=...

# OpenRouter
# OPENROUTER_API_KEY=...
